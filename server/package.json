{
    "name": "zyvan-server",
    "version": "1.0.0",
    "description": "Zyvan Core Reliability Engine",
    "main": "dist/index.js",
    "private": true,
    "scripts": {
        "dev": "nodemon --exec ts-node src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint src --ext .ts",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "test:coverage": "vitest run --config vitest.config.ts --coverage"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bullmq": "^5.0.0",
        "dotenv": "^16.0.0",
        "express": "^4.18.0",
        "ioredis": "^5.3.0",
        "pg": "^8.11.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "prisma": "^5.22.0",
        "zod": "^3.22.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.0.0",
        "@types/pg": "^8.11.0",
        "@types/pino": "^7.0.4",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.0.18",
        "nodemon": "^3.0.0",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.0",
        "typescript": "^5.3.0",
        "vitest": "^1.6.1"
    }
}